---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PersonCard from '../../components/PersonCard.astro';
import PublicationItem from '../../components/PublicationItem.astro';
import { resolveDisplayName } from '../../utils/people';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const projects = await getCollection('projects');
  return projects.map(p => ({ params: { slug: p.id }, props: { project: p } }));
};

const { project } = Astro.props;
const { Content } = await render(project);

const allPeople = await getCollection('people');
const peopleById = Object.fromEntries(allPeople.map(p => [p.data.id, p.data]));
const projectPeople = project.data.people
  .map((id: string) => peopleById[id])
  .filter(Boolean);

const allPublications = await getCollection('publications');
const pubsByKey = Object.fromEntries(
  allPublications.filter(p => p.data.key).map(p => [p.data.key!, p.data])
);
const projectPubs = (project.data.publications ?? [])
  .map((key: string) => pubsByKey[key])
  .filter(Boolean);
---

<Base title={project.data.title}>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    <div class="mb-2">
      <a href="/research" class="text-sm text-[#552d62] hover:underline">← All projects</a>
    </div>

    <div class="flex items-start justify-between gap-4 mb-6 mt-4">
      <h1 class="text-3xl font-bold text-gray-900">{project.data.title}</h1>
      {project.data.status === 'inactive' && (
        <span class="flex-shrink-0 text-sm font-medium text-gray-400 bg-gray-100 px-3 py-1 rounded-full mt-1">Past</span>
      )}
    </div>

    <div class="prose prose-lg max-w-none prose-a:text-[#552d62] prose-headings:text-gray-900 mb-10">
      <Content />
    </div>

    {projectPeople.length > 0 && (
      <div class="border-t border-gray-100 pt-8">
        <h2 class="text-lg font-semibold text-gray-700 mb-4">People involved</h2>
        <div class="flex flex-wrap gap-6">
          {projectPeople.map((p: any) => (
            <PersonCard
              name={resolveDisplayName(p)}
              role={p.role}
              bio={p.bio}
              image={p.image}
              webpage={p.webpage}
              variant="card"
            />
          ))}
        </div>
      </div>
    )}

    {projectPubs.length > 0 && (
      <div class="border-t border-gray-100 pt-8 mt-8">
        <h2 class="text-lg font-semibold text-gray-700 mb-4">Related publications</h2>
        <ul class="divide-y divide-gray-100">
          {projectPubs.map((pub: any) => (
            <PublicationItem
              title={pub.title}
              authors={pub.authors}
              journal={pub.journal}
              year={pub.year}
              doi={pub.doi}
              url={pub.url}
              abstract={pub.abstract}
              isCover={pub.isCover}
              coverImage={pub.coverImage}
              coverThumb={pub.coverThumb}
            />
          ))}
        </ul>
      </div>
    )}

    <div class="mt-8 text-xs text-gray-400">
      Last updated: {project.data.lastUpdated.toLocaleDateString('en-GB', { month: 'long', year: 'numeric' })}
    </div>
  </div>
</Base>
