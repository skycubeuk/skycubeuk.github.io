---
import Base from '../layouts/Base.astro';
---

<Base title="Page Not Found | WY Chow Lab" description="The page you're looking for doesn't exist.">
  <div class="max-w-2xl mx-auto px-4 py-24 text-center">
    <p class="text-7xl mb-4">🔭</p>
    <h1 class="text-4xl font-bold text-gray-900 mb-4">Page not found</h1>
    <p class="text-gray-500 mb-8">Sorry, we couldn't find what you were looking for.</p>
    <a href="/" class="inline-block px-6 py-3 rounded-full bg-[#552d62] text-white font-medium hover:bg-[#3f1f4a] transition-colors">
      Back to home
    </a>
  </div>
</Base>
