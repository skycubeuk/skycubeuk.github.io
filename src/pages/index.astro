---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import NewsItem from '../components/NewsItem.astro';
import ProjectCard from '../components/ProjectCard.astro';
import PersonCard from '../components/PersonCard.astro';
import { resolveDisplayName } from '../utils/people';

// Load data
const allPosts = (await getCollection('posts')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const recentPosts = allPosts.slice(0, 5);

const allProjects = (await getCollection('projects'))
  .filter(p => p.data.status === 'active')
  .sort((a, b) => b.data.lastUpdated.getTime() - a.data.lastUpdated.getTime());

const allPeople = (await getCollection('people')).sort((a, b) => a.data.order - b.data.order);
const peopleById = Object.fromEntries(allPeople.map(p => [p.data.id, p.data]));

const faculty   = allPeople.filter(p => p.data.role === 'faculty');
const students  = allPeople.filter(p => p.data.role === 'student');
const collabs   = allPeople.filter(p => p.data.role === 'collab');
const alumni    = allPeople.filter(p => ['alum', 'ugrad-alum'].includes(p.data.role));

// Funding data grouped by funding body
const today = new Date();
today.setHours(0, 0, 0, 0);

const siteSettings = (await getCollection('settings'))[0];
const showPastFunding: boolean = siteSettings?.data.showPastFunding ?? true;

const allFunding = await getCollection('funding');
const allFundingBodies = await getCollection('fundingBody');
const fundingBodiesById = Object.fromEntries(allFundingBodies.map(fb => [fb.data.id, fb.data]));

// When showPastFunding is false, past grants look identical to active — include all.
// When showPastFunding is true, only active grants appear on the front page.
const grantsForIndex = showPastFunding
  ? allFunding.filter(g => !g.data.endDate || g.data.endDate >= today)
  : allFunding;

// Group by funding body, preserving encounter order
const fundingGroups = new Map<string, { body: typeof allFundingBodies[0]['data']; grants: typeof allFunding }>();
for (const grant of grantsForIndex) {
  const bodyId = grant.data.fundingBody;
  const body = fundingBodiesById[bodyId];
  if (!body) continue;
  if (!fundingGroups.has(bodyId)) {
    fundingGroups.set(bodyId, { body, grants: [] });
  }
  fundingGroups.get(bodyId)!.grants.push(grant);
}
---

<Base>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-[#552d62] to-[#3f1f4a] text-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-20">
      <div class="max-w-2xl">
        <p class="text-purple-200 text-sm font-semibold uppercase tracking-widest mb-4">
          Department of Physics · University of Warwick
        </p>
        <h1 class="text-4xl sm:text-5xl font-bold leading-tight mb-6">
          Using magnetic resonance to deliver new insight to human health and disease.
        </h1>
        <p class="text-purple-100 text-lg leading-relaxed">
          We use solid-state NMR spectroscopy to study biomolecules in the extracellular matrix
          at atomic resolution — revealing structural details relevant to disease and ageing.
        </p>
        <div class="flex flex-wrap gap-3 mt-8">
          <a href="/research" class="px-5 py-2.5 bg-white text-[#552d62] font-semibold rounded-full hover:bg-purple-50 transition-colors text-sm">
            Our Research
          </a>
          <a href="/join" class="px-5 py-2.5 border border-white/50 text-white font-semibold rounded-full hover:bg-white/10 transition-colors text-sm">
            Join the Lab
          </a>
        </div>
      </div>
    </div>
  </section>

  <div class="max-w-5xl mx-auto px-4 sm:px-6">

    <!-- News + Research two-column -->
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 py-14">

      <!-- News (left, narrower) -->
      <section class="lg:col-span-2">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-2xl font-bold text-gray-900">News</h2>
          <a href="/posts" class="text-sm text-[#552d62] hover:underline">All posts →</a>
        </div>
        <ul class="divide-y divide-gray-100">
          {recentPosts.map(post => (
            <NewsItem
              date={post.data.date}
              icon={post.data.icon}
              title={post.data.title}
              excerpt={post.body?.slice(0, 200).replace(/---[\s\S]*?---/, '').trim() ?? ''}
              slug={post.id}
              displayimage={post.data.displayimage}
              shortnews={post.data.shortnews}
            />
          ))}
        </ul>
      </section>

      <!-- Research (right, wider) -->
      <section class="lg:col-span-3">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-2xl font-bold text-gray-900">Research</h2>
          <a href="/research" class="text-sm text-[#552d62] hover:underline">All projects →</a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {allProjects.map(project => {
            const projectPeople = project.data.people
              .map((id: string) => peopleById[id])
              .filter(Boolean);
            return (
              <ProjectCard
                title={project.data.title}
                excerpt={project.data.excerpt}
                slug={project.id}
                status={project.data.status}
                people={projectPeople}
                lastUpdated={project.data.lastUpdated}
              />
            );
          })}
        </div>
      </section>
    </div>

    <!-- People -->
    <section id="people" class="py-14 border-t border-gray-100">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">People</h2>

      <!-- Faculty -->
      <div class="mb-10">
        {faculty.map(p => (
          <PersonCard
            name={resolveDisplayName(p.data)}
            firstName={p.data.firstName}
            role={p.data.role}
            bio={p.data.bio}
            bioLong={p.data.bioLong}
            image={p.data.image}
            webpage={p.data.webpage}
            twitter={p.data.twitter}
            mastodon={p.data.mastodon}
            orcid={p.data.orcid}
            github={p.data.github}
            linkedin={p.data.linkedin}
            bluesky={p.data.bluesky}
            variant="full"
          />
        ))}
      </div>

      <!-- Students -->
      <div class="mb-10" data-student-section>
        <div class="flex items-end justify-between mb-4">
          <h3 class="text-lg font-semibold text-gray-700">Research Students</h3>
          <button class="text-xs text-[#552d62] hover:underline" data-expand-all>Expand all</button>
        </div>
        <div class="flex flex-wrap gap-6">
          {students.map((p, i) => (
            <>
              <div class="w-[calc(50%-12px)] sm:w-[calc(33.333%-16px)] md:w-[calc(20%-19.2px)]" data-card-wrapper data-card-idx={i} style={`order: ${i * 10}`}>
                <PersonCard
                  name={resolveDisplayName(p.data)}
                  firstName={p.data.firstName}
                  role={p.data.role}
                  roleLabel={p.data.roleLabel}
                  bio={p.data.bio}
                  image={p.data.image}
                  webpage={p.data.webpage}
                  twitter={p.data.twitter}
                  mastodon={p.data.mastodon}
                  orcid={p.data.orcid}
                  github={p.data.github}
                  linkedin={p.data.linkedin}
                  bluesky={p.data.bluesky}
                  variant="card"
                />
                {p.data.bioLong && (
                  <div class="flex justify-center mt-2">
                    <button class="text-xs text-[#552d62] hover:underline" data-expand-btn data-card-idx={i} aria-expanded="false">▼ More</button>
                  </div>
                )}
              </div>
              {p.data.bioLong && (
                <div class="w-full hidden" data-drawer data-drawer-idx={i} style={`order: ${i * 10 + 1}`}>
                  <div class="mt-1 mb-3 bg-gray-50 rounded-xl overflow-hidden border border-gray-100">
                    <div class="h-0.5 bg-[#552d62]"></div>
                    <div class="p-5 flex items-start gap-4">
                      <div class="flex-shrink-0">
                        {p.data.image ? (
                          <img src={p.data.image} alt={resolveDisplayName(p.data)} class="w-16 h-16 rounded-full object-cover ring-2 ring-[#552d62]/20" />
                        ) : (
                          <div class="w-16 h-16 rounded-full flex items-center justify-center text-xl font-bold text-white bg-[#552d62]">
                            {(p.data.firstName ?? resolveDisplayName(p.data)).charAt(0).toUpperCase()}
                          </div>
                        )}
                      </div>
                      <div class="flex-1 min-w-0">
                        <div class="flex items-start justify-between gap-4">
                          <div>
                            <p class="font-semibold text-gray-900">
                              {p.data.webpage
                                ? <a href={p.data.webpage} class="hover:text-[#552d62]">{resolveDisplayName(p.data)}</a>
                                : resolveDisplayName(p.data)
                              }
                            </p>
                            {p.data.roleLabel && <p class="text-xs text-gray-500 mt-0.5">({p.data.roleLabel})</p>}
                          </div>
                          <button data-close-drawer data-drawer-idx={i} class="text-gray-400 hover:text-gray-600 flex-shrink-0 text-xl leading-none" aria-label="Close">×</button>
                        </div>
                        <p class="text-sm text-gray-700 leading-relaxed mt-3">{p.data.bioLong}</p>
                      </div>
                    </div>
                  </div>
                </div>
              )}
            </>
          ))}
          <!-- You? placeholder -->
          <div class="w-[calc(50%-12px)] sm:w-[calc(33.333%-16px)] md:w-[calc(20%-19.2px)]" style={`order: ${students.length * 10}`}>
            <div class="flex flex-col items-center text-center gap-2 w-full">
              <a href="/join" class="w-16 h-16 rounded-full bg-gray-200 flex items-center justify-center text-2xl font-bold text-gray-400 hover:bg-[#552d62] hover:text-white transition-colors ring-2 ring-gray-100">?</a>
              <div>
                <p class="text-sm font-medium text-gray-500">
                  <a href="/join" class="hover:text-[#552d62]">You?</a>
                </p>
                <p class="text-xs text-gray-400">See the Join page!</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Collaborators + Alumni -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        <div>
          <h3 class="text-lg font-semibold text-gray-700 mb-3">Collaborators</h3>
          <ul class="space-y-2">
            {collabs.map(p => (
              <li class="text-sm">
                {p.data.webpage
                  ? <a href={p.data.webpage} class="font-medium text-[#552d62] hover:underline">{resolveDisplayName(p.data)}</a>
                  : <span class="font-medium text-gray-800">{resolveDisplayName(p.data)}</span>
                }
                {p.data.bio && <span class="text-gray-500"> — {p.data.bio}</span>}
              </li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="text-lg font-semibold text-gray-700 mb-3">Alumni</h3>
          <ul class="space-y-1.5">
            {alumni.map(p => (
              <li class="text-sm">
                {p.data.webpage
                  ? <a href={p.data.webpage} class="text-gray-700 hover:text-[#552d62]">{resolveDisplayName(p.data)}</a>
                  : <span class="text-gray-700">{resolveDisplayName(p.data)}</span>
                }
                {p.data.nextRole && <span class="text-gray-400"> → {p.data.nextRole}</span>}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>
  </div>

  {fundingGroups.size > 0 && (
    <section class="bg-gray-50 border-t border-gray-200 mt-4">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 py-14">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-2xl font-bold text-gray-900">Funding</h2>
          <a href="/funding" class="text-sm text-[#552d62] hover:underline">All funding →</a>
        </div>
        <div class="flex flex-wrap gap-4">
          {[...fundingGroups.values()].map(({ body }) => (
            <div class="flex items-center gap-3 bg-white border border-gray-200 rounded-lg px-4 py-3">
              {body.logo && (
                <img src={body.logo} alt={body.name} class="h-8 w-auto object-contain flex-shrink-0" onerror="this.style.display='none'" />
              )}
              <span class="text-sm font-semibold text-gray-700">
                {body.url
                  ? <a href={body.url} class="hover:text-[#552d62] hover:underline" target="_blank" rel="noopener noreferrer">{body.name}</a>
                  : body.name
                }
              </span>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}
</Base>

<script>
(function () {
  document.querySelectorAll<HTMLElement>('[data-student-section]').forEach(section => {
    const expandAllBtn = section.querySelector<HTMLButtonElement>('[data-expand-all]');

    function cardWrappers(): HTMLElement[] {
      return [...section.querySelectorAll<HTMLElement>('[data-card-wrapper]')];
    }
    function getDrawer(idx: string | number): HTMLElement | null {
      return section.querySelector<HTMLElement>(`[data-drawer-idx="${idx}"]`);
    }
    function rowMates(card: HTMLElement, all: HTMLElement[]): HTMLElement[] {
      const top = card.getBoundingClientRect().top;
      return all.filter(c => Math.abs(c.getBoundingClientRect().top - top) < 5);
    }
    function rowMaxOrder(cards: HTMLElement[]): number {
      return Math.max(...cards.map(c => parseInt(c.style.order || '0', 10)));
    }

    function open(idx: string, closeRow = true): void {
      const all = cardWrappers();
      const card = all.find(c => c.dataset.cardIdx === idx);
      const d = getDrawer(idx);
      if (!card || !d) return;
      if (closeRow) {
        rowMates(card, all).forEach(rc => { if (rc.dataset.cardIdx !== idx) close(rc.dataset.cardIdx!); });
      }
      const mates = rowMates(card, all);
      d.style.order = String(rowMaxOrder(mates) + 1);
      d.classList.remove('hidden');
      const btn = card.querySelector<HTMLElement>('[data-expand-btn]');
      if (btn) { btn.setAttribute('aria-expanded', 'true'); btn.textContent = '▲ Less'; }
    }

    function close(idx: string): void {
      const d = getDrawer(idx);
      if (!d || d.classList.contains('hidden')) return;
      d.classList.add('hidden');
      const card = section.querySelector<HTMLElement>(`[data-card-wrapper][data-card-idx="${idx}"]`);
      const btn = card?.querySelector<HTMLElement>('[data-expand-btn]');
      if (btn) { btn.setAttribute('aria-expanded', 'false'); btn.textContent = '▼ More'; }
    }

    section.querySelectorAll<HTMLElement>('[data-expand-btn]').forEach(btn => {
      btn.addEventListener('click', () => {
        const idx = btn.dataset.cardIdx!;
        btn.getAttribute('aria-expanded') === 'true' ? close(idx) : open(idx);
      });
    });
    section.querySelectorAll<HTMLElement>('[data-close-drawer]').forEach(btn => {
      btn.addEventListener('click', () => close(btn.dataset.drawerIdx!));
    });

    if (expandAllBtn) {
      expandAllBtn.addEventListener('click', () => {
        if (expandAllBtn.textContent?.trim() === 'Expand all') {
          const all = cardWrappers();
          const withBio = all.filter(c => c.querySelector('[data-expand-btn]'));
          const orders = new Map<string, number>();
          withBio.forEach(card => { orders.set(card.dataset.cardIdx!, rowMaxOrder(rowMates(card, all)) + 1); });
          withBio.forEach(card => {
            const idx = card.dataset.cardIdx!;
            const d = getDrawer(idx);
            if (!d) return;
            d.style.order = String(orders.get(idx)!);
            d.classList.remove('hidden');
            const btn = card.querySelector<HTMLElement>('[data-expand-btn]');
            if (btn) { btn.setAttribute('aria-expanded', 'true'); btn.textContent = '▲ Less'; }
          });
          expandAllBtn.textContent = 'Collapse all';
        } else {
          cardWrappers().forEach(c => close(c.dataset.cardIdx!));
          expandAllBtn.textContent = 'Expand all';
        }
      });
    }

    let resizeTimer: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        const all = cardWrappers();
        section.querySelectorAll<HTMLElement>('[data-drawer]:not(.hidden)').forEach(d => {
          const card = all.find(c => c.dataset.cardIdx === d.dataset.drawerIdx);
          if (!card) return;
          d.style.order = String(rowMaxOrder(rowMates(card, all)) + 1);
        });
      }, 150);
    });
  });
})();
</script>
