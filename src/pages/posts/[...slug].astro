---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getCollection('posts');
  return posts.map(p => ({ params: { slug: p.id }, props: { post: p } }));
};

const { post } = Astro.props;
const { Content } = await render(post);
const { title, date, icon, displayimage, shortnews } = post.data;

const iconMap: Record<string, string> = {
  'newspaper': '📰',
  'graduation-cap': '🎓',
  'flask': '🧪',
  'person-chalkboard': '🏛️',
  'id-badge': '👤',
  'bullhorn': '📢',
  'microscope': '🔬',
  'plane': '✈️',
  'fa-solid fa-flask': '🧪',
};
const emoji = iconMap[icon ?? 'newspaper'] ?? '📰';
---

<Base title={title ?? 'News'}>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    <div class="mb-6">
      <a href="/posts" class="text-sm text-[#552d62] hover:underline">← All posts</a>
    </div>

    {displayimage && (
      <img
        src={displayimage.src}
        alt={displayimage.alt}
        class="w-full max-h-72 object-cover rounded-2xl mb-8"
      />
    )}

    <header class="mb-8">
      <div class="flex items-center gap-2 text-gray-400 text-sm mb-3">
        <span aria-hidden="true" class="text-xl">{emoji}</span>
        <time datetime={date.toISOString()}>
          {date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
        </time>
      </div>
      {!shortnews && title && (
        <h1 class="text-3xl font-bold text-gray-900">{title}</h1>
      )}
    </header>

    <div class="prose prose-lg max-w-none prose-a:text-[#552d62] prose-headings:text-gray-900">
      <Content />
    </div>

    <div class="mt-10 pt-6 border-t border-gray-200">
      <a href="/posts" class="text-sm text-[#552d62] hover:underline">← All news posts</a>
    </div>
  </article>
</Base>
