---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import NewsItem from '../../components/NewsItem.astro';

const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<Base title="News Posts">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    <h1 class="text-3xl font-bold text-gray-900 mb-8">Posts</h1>
    <ul class="divide-y divide-gray-100">
      {posts.map(post => (
        <NewsItem
          date={post.data.date}
          icon={post.data.icon}
          title={post.data.title}
          excerpt={post.body?.slice(0, 300) ?? ''}
          slug={post.id}
          displayimage={post.data.displayimage}
          shortnews={post.data.shortnews}
        />
      ))}
    </ul>
  </div>
</Base>
