---
interface Props {
  title: string;
  authors: string;
  journal: string;
  year: number;
  doi?: string;
  url?: string;
  abstract?: string;
  isCover?: boolean;
  coverImage?: string;
  coverThumb?: string;
}

const { title, authors, journal, year, doi, url, abstract, isCover, coverThumb } = Astro.props;
const href = doi ? `https://doi.org/${doi}` : url;
const id = `pub-${Math.random().toString(36).slice(2, 8)}`;
---

<div class="py-4 border-b border-gray-100 last:border-0">
  <div class="flex gap-3">
    {isCover && coverThumb && (
      <img src={coverThumb} alt="Journal cover" class="w-10 h-14 object-cover rounded flex-shrink-0" />
    )}
    <div class="flex-1 min-w-0">
      <p class="text-sm font-semibold text-gray-900 leading-snug">
        {href ? (
          <a href={href} target="_blank" rel="noopener noreferrer" class="hover:text-[#552d62] transition-colors">{title}</a>
        ) : title}
      </p>
      <p class="text-xs text-gray-500 mt-1">{authors}</p>
      <p class="text-xs text-gray-400 mt-0.5 italic">{journal}, {year}</p>
      {doi && (
        <a href={`https://doi.org/${doi}`} target="_blank" rel="noopener noreferrer"
           class="text-xs text-[#552d62] hover:underline mt-0.5 inline-block">
          doi:{doi}
        </a>
      )}
      {abstract && (
        <div>
          <button
            class="text-xs text-gray-400 hover:text-[#552d62] mt-1 transition-colors"
            onclick={`document.getElementById('${id}').classList.toggle('hidden')`}
          >
            [abstract ▾]
          </button>
          <p id={id} class="hidden mt-2 text-xs text-gray-600 leading-relaxed bg-gray-50 rounded p-3">
            {abstract}
          </p>
        </div>
      )}
    </div>
  </div>
</div>
