---
interface Props {
  name: string;
  firstName?: string;
  role: string;
  bio?: string;
  bioLong?: string;
  image?: string;
  webpage?: string;
  twitter?: string;
  mastodon?: string;
  orcid?: string;
  github?: string;
  linkedin?: string;
  bluesky?: string;
  roleLabel?: string;
  nextRole?: string;
  variant?: 'full' | 'card' | 'mini';
}

const {
  name, firstName, role, bio, bioLong, image, webpage, twitter, mastodon, orcid, github, linkedin, bluesky,
  roleLabel, nextRole, variant = 'card',
} = Astro.props;

const initial = (firstName ?? name).charAt(0).toUpperCase();
const roleColors: Record<string, string> = {
  faculty: 'bg-[#552d62]',
  postdoc: 'bg-purple-500',
  student: 'bg-[#552d62]',
  collab: 'bg-gray-400',
  'ugrad-alum': 'bg-gray-300',
  alum: 'bg-gray-300',
};
const bgColor = roleColors[role] ?? 'bg-gray-400';
---

{variant === 'full' && (
  <div class="flex flex-col sm:flex-row gap-6 p-6 bg-white rounded-2xl border border-gray-100 shadow-sm">
    {image ? (
      <img src={image} alt={name} class="w-28 h-28 rounded-full object-cover flex-shrink-0 ring-4 ring-[#552d62]/20" />
    ) : (
      <div class={`w-28 h-28 rounded-full flex-shrink-0 flex items-center justify-center text-4xl font-bold text-white ${bgColor}`}>
        {initial}
      </div>
    )}
    <div class="flex-1 min-w-0">
      <h3 class="text-xl font-bold text-gray-900">
        {webpage ? <a href={webpage} class="hover:text-[#552d62] transition-colors">{name}</a> : name}
      </h3>
      {bio && <p class="text-sm text-gray-500 mt-0.5">{bio}</p>}
      {bioLong && <p class="mt-3 text-gray-700 text-sm leading-relaxed">{bioLong}</p>}
      <div class="flex flex-wrap gap-3 mt-3">
        {orcid && (
          <a href={`https://orcid.org/${orcid}`} class="flex items-center gap-1 text-xs text-gray-500 hover:text-[#552d62]" title="ORCID">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zM7.369 4.378c.525 0 .947.431.947.947s-.422.947-.947.947a.95.95 0 0 1-.947-.947c0-.525.422-.947.947-.947zm-.722 3.038h1.444v10.041H6.647V7.416zm3.562 0h3.9c3.712 0 5.344 2.653 5.344 5.025 0 2.578-2.016 5.025-5.325 5.025h-3.919V7.416zm1.444 1.303v7.444h2.297c3.272 0 4.022-2.484 4.022-3.722 0-2.016-1.284-3.722-4.097-3.722h-2.222z"/></svg>
            {orcid}
          </a>
        )}
        {twitter && (
          <a href={`https://twitter.com/${twitter}`} class="flex items-center gap-1 text-xs text-gray-500 hover:text-[#552d62]" title="Twitter">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            @{twitter}
          </a>
        )}
        {mastodon && (
          <a href={mastodon} class="flex items-center gap-1 text-xs text-gray-500 hover:text-[#552d62]" title="Mastodon" rel="me">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M23.268 5.313c-.35-2.578-2.617-4.61-5.304-5.004C17.51.242 15.792 0 11.813 0h-.03c-3.98 0-4.835.242-5.288.309C3.882.692 1.496 2.518.917 5.127.64 6.412.61 7.837.661 9.143c.074 1.874.088 3.745.26 5.611.118 1.24.325 2.47.62 3.68.55 2.237 2.777 4.098 4.96 4.857 2.336.792 4.849.923 7.256.38.265-.061.527-.132.786-.213.585-.184 1.27-.39 1.774-.753a.057.057 0 0 0 .023-.043v-1.809a.052.052 0 0 0-.02-.041.053.053 0 0 0-.046-.01 20.282 20.282 0 0 1-4.709.545c-2.73 0-3.463-1.284-3.674-1.818a5.593 5.593 0 0 1-.319-1.433.053.053 0 0 1 .066-.054c1.517.363 3.072.546 4.632.546.376 0 .75 0 1.125-.01 1.57-.044 3.224-.124 4.768-.422.038-.008.077-.015.11-.024 2.435-.464 4.753-1.92 4.989-5.604.008-.145.03-1.52.03-1.67.002-.512.167-3.63-.024-5.545zm-3.748 9.195h-2.561V8.29c0-1.309-.55-1.976-1.67-1.976-1.23 0-1.846.79-1.846 2.35v3.403h-2.546V8.663c0-1.56-.617-2.35-1.848-2.35-1.112 0-1.668.668-1.67 1.977v6.218H4.822V8.102c0-1.31.337-2.35 1.011-3.12.696-.77 1.608-1.164 2.74-1.164 1.311 0 2.302.5 2.962 1.498l.638 1.06.638-1.06c.66-.999 1.65-1.498 2.96-1.498 1.13 0 2.043.395 2.74 1.164.675.77 1.012 1.81 1.012 3.12z"/></svg>
            Mastodon
          </a>
        )}
        {bluesky && (
          <a href={`https://bsky.app/profile/${bluesky}`} class="flex items-center gap-1 text-xs text-gray-500 hover:text-[#552d62]" title="Bluesky">
            <svg class="w-4 h-4" viewBox="0 0 600 530" fill="currentColor"><path d="M135.72 44.03C202.216 93.951 273.74 195.17 300 249.49c26.262-54.316 97.782-155.54 164.28-205.46C512.26 8.009 590-19.862 590 68.825c0 17.712-10.155 148.79-16.111 170.07-20.703 73.984-96.144 92.854-163.25 81.433 117.3 19.964 147.14 86.092 82.697 152.22-122.39 125.59-175.91-31.511-189.63-71.766-2.514-7.38-3.69-10.832-3.708-7.896-.017-2.936-1.193.516-3.707 7.896-13.714 40.255-67.233 197.36-189.63 71.766-64.444-66.128-34.605-132.26 82.697-152.22-67.108 11.421-142.55-7.45-163.25-81.433C20.15 217.613 10 86.535 10 68.825c0-88.687 77.742-60.816 125.72-24.795z"/></svg>
            @{bluesky}
          </a>
        )}
        {github && (
          <a href={`https://github.com/${github}`} class="flex items-center gap-1 text-xs text-gray-500 hover:text-[#552d62]" title="GitHub">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
            {github}
          </a>
        )}
        {linkedin && (
          <a href={linkedin} class="flex items-center gap-1 text-xs text-gray-500 hover:text-[#552d62]" title="LinkedIn">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>
        )}
      </div>
    </div>
  </div>
)}

{variant === 'card' && (
  <div class="flex flex-col items-center text-center gap-2 w-full">
    {image ? (
      <img src={image} alt={name} class="w-16 h-16 rounded-full object-cover ring-2 ring-gray-200 flex-shrink-0" />
    ) : (
      <div class={`w-16 h-16 rounded-full flex-shrink-0 flex items-center justify-center text-xl font-bold text-white ${bgColor}`}>
        {initial}
      </div>
    )}
    <div class="w-full">
      <p class="text-sm font-medium text-gray-900 leading-snug">
        {webpage ? <a href={webpage} class="hover:text-[#552d62] transition-colors">{name}</a> : name}
      </p>
      {roleLabel && <p class="text-sm font-medium text-gray-900 leading-snug">({roleLabel})</p>}
      {bio && <p class="text-xs text-gray-500 mt-0.5 leading-snug line-clamp-2">{bio}</p>}
      {(orcid || twitter || mastodon || bluesky || github || linkedin) && (
        <div class="flex items-center justify-center gap-2 mt-1.5">
          {orcid && (
            <a href={`https://orcid.org/${orcid}`} class="text-gray-400 hover:text-[#552d62] transition-colors" title="ORCID" aria-label="ORCID">
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zM7.369 4.378c.525 0 .947.431.947.947s-.422.947-.947.947a.95.95 0 0 1-.947-.947c0-.525.422-.947.947-.947zm-.722 3.038h1.444v10.041H6.647V7.416zm3.562 0h3.9c3.712 0 5.344 2.653 5.344 5.025 0 2.578-2.016 5.025-5.325 5.025h-3.919V7.416zm1.444 1.303v7.444h2.297c3.272 0 4.022-2.484 4.022-3.722 0-2.016-1.284-3.722-4.097-3.722h-2.222z"/></svg>
            </a>
          )}
          {twitter && (
            <a href={`https://twitter.com/${twitter}`} class="text-gray-400 hover:text-[#552d62] transition-colors" title="Twitter" aria-label="Twitter">
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
          )}
          {mastodon && (
            <a href={mastodon} class="text-gray-400 hover:text-[#552d62] transition-colors" title="Mastodon" aria-label="Mastodon" rel="me">
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M23.268 5.313c-.35-2.578-2.617-4.61-5.304-5.004C17.51.242 15.792 0 11.813 0h-.03c-3.98 0-4.835.242-5.288.309C3.882.692 1.496 2.518.917 5.127.64 6.412.61 7.837.661 9.143c.074 1.874.088 3.745.26 5.611.118 1.24.325 2.47.62 3.68.55 2.237 2.777 4.098 4.96 4.857 2.336.792 4.849.923 7.256.38.265-.061.527-.132.786-.213.585-.184 1.27-.39 1.774-.753a.057.057 0 0 0 .023-.043v-1.809a.052.052 0 0 0-.02-.041.053.053 0 0 0-.046-.01 20.282 20.282 0 0 1-4.709.545c-2.73 0-3.463-1.284-3.674-1.818a5.593 5.593 0 0 1-.319-1.433.053.053 0 0 1 .066-.054c1.517.363 3.072.546 4.632.546.376 0 .75 0 1.125-.01 1.57-.044 3.224-.124 4.768-.422.038-.008.077-.015.11-.024 2.435-.464 4.753-1.92 4.989-5.604.008-.145.03-1.52.03-1.67.002-.512.167-3.63-.024-5.545zm-3.748 9.195h-2.561V8.29c0-1.309-.55-1.976-1.67-1.976-1.23 0-1.846.79-1.846 2.35v3.403h-2.546V8.663c0-1.56-.617-2.35-1.848-2.35-1.112 0-1.668.668-1.67 1.977v6.218H4.822V8.102c0-1.31.337-2.35 1.011-3.12.696-.77 1.608-1.164 2.74-1.164 1.311 0 2.302.5 2.962 1.498l.638 1.06.638-1.06c.66-.999 1.65-1.498 2.96-1.498 1.13 0 2.043.395 2.74 1.164.675.77 1.012 1.81 1.012 3.12z"/></svg>
            </a>
          )}
          {bluesky && (
            <a href={`https://bsky.app/profile/${bluesky}`} class="text-gray-400 hover:text-[#552d62] transition-colors" title="Bluesky" aria-label="Bluesky">
              <svg class="w-3.5 h-3.5" viewBox="0 0 600 530" fill="currentColor"><path d="M135.72 44.03C202.216 93.951 273.74 195.17 300 249.49c26.262-54.316 97.782-155.54 164.28-205.46C512.26 8.009 590-19.862 590 68.825c0 17.712-10.155 148.79-16.111 170.07-20.703 73.984-96.144 92.854-163.25 81.433 117.3 19.964 147.14 86.092 82.697 152.22-122.39 125.59-175.91-31.511-189.63-71.766-2.514-7.38-3.69-10.832-3.708-7.896-.017-2.936-1.193.516-3.707 7.896-13.714 40.255-67.233 197.36-189.63 71.766-64.444-66.128-34.605-132.26 82.697-152.22-67.108 11.421-142.55-7.45-163.25-81.433C20.15 217.613 10 86.535 10 68.825c0-88.687 77.742-60.816 125.72-24.795z"/></svg>
            </a>
          )}
          {github && (
            <a href={`https://github.com/${github}`} class="text-gray-400 hover:text-[#552d62] transition-colors" title="GitHub" aria-label="GitHub">
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
            </a>
          )}
          {linkedin && (
            <a href={linkedin} class="text-gray-400 hover:text-[#552d62] transition-colors" title="LinkedIn" aria-label="LinkedIn">
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
          )}
        </div>
      )}
    </div>
  </div>
)}

{variant === 'mini' && (
  <div>
    {webpage ? (
      <a href={webpage} class="font-medium text-[#552d62] hover:underline">{name}</a>
    ) : (
      <span class="text-gray-700">{name}</span>
    )}
    {bio && <span class="text-gray-500 text-sm"> — {bio}</span>}
    {nextRole && <span class="text-gray-400 text-sm"> → {nextRole}</span>}
  </div>
)}
