---
import { resolveDisplayName, getInitial } from '../utils/people';

interface Props {
  title: string;
  excerpt: string;
  slug: string;
  status: string;
  people: Array<{ displayName?: string; title?: string; firstName?: string; lastName?: string; image?: string; id: string; webpage?: string }>;
  lastUpdated: Date;
}

const { title, excerpt, slug, status, people, lastUpdated } = Astro.props;
---

<article class="bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow p-6 flex flex-col gap-4">
  <div class="flex items-start justify-between gap-2">
    <h3 class="text-lg font-bold text-gray-900 leading-snug">
      <a href={`/projects/${slug}`} class="hover:text-[#552d62] transition-colors">{title}</a>
    </h3>
    {status === 'inactive' && (
      <span class="flex-shrink-0 text-xs font-medium text-gray-400 bg-gray-100 px-2 py-0.5 rounded-full">Past</span>
    )}
  </div>
  <p class="text-gray-600 text-sm leading-relaxed flex-1">{excerpt}</p>
  <div class="flex items-center justify-between gap-4 flex-wrap">
    <!-- People avatars -->
    <div class="flex -space-x-2">
      {people.map((p) => (
        p.image ? (
          <img
            src={p.image}
            alt={resolveDisplayName(p)}
            title={resolveDisplayName(p)}
            class="w-8 h-8 rounded-full ring-2 ring-white object-cover"
          />
        ) : (
          <div
            title={resolveDisplayName(p)}
            class="w-8 h-8 rounded-full ring-2 ring-white bg-[#552d62] flex items-center justify-center text-white text-xs font-bold"
          >
            {getInitial(p)}
          </div>
        )
      ))}
    </div>
    <a href={`/projects/${slug}`} class="text-sm font-medium text-[#552d62] hover:underline">
      Read more →
    </a>
  </div>
</article>
