---
interface Props {
  date: Date;
  icon?: string;
  title?: string;
  excerpt: string;
  slug: string;
  displayimage?: { src: string; alt: string };
  shortnews?: boolean;
}

const { date, icon = 'newspaper', title, excerpt, slug, displayimage, shortnews } = Astro.props;

const iconMap: Record<string, string> = {
  'newspaper': '📰',
  'graduation-cap': '🎓',
  'flask': '🧪',
  'person-chalkboard': '🏛️',
  'id-badge': '👤',
  'bullhorn': '📢',
  'microscope': '🔬',
  'plane': '✈️',
  'fa-solid fa-flask': '🧪',
};
const emoji = iconMap[icon] ?? '📰';
const formattedDate = date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });

// Strip markdown syntax so raw .md body doesn't bleed into preview text
const cleanExcerpt = excerpt
  .replace(/\[([^\]]+)\]\([^\)]+\)/g, '$1')   // [text](url) → text
  .replace(/!\[[^\]]*\]\([^\)]+\)/g, '')        // images
  .replace(/[*_`#>]/g, '')                       // bold/italic/code/headings/blockquotes
  .replace(/\s+/g, ' ')
  .trim()
  .slice(0, 200);
---

<li class="group">
  <div class={`py-4 border-b border-gray-100`}>
    <div class="flex items-start gap-3">
      <span aria-hidden="true" class="text-lg mt-0.5 flex-shrink-0">{emoji}</span>
      <div class="flex-1 min-w-0">
        <time datetime={date.toISOString()} class="text-xs text-gray-400 block mb-1">{formattedDate}</time>
        {title && (
          <h3 class="font-semibold text-gray-900 mb-1">
            <a href={`/posts/${slug}`} class="hover:text-[#552d62] transition-colors">{title}</a>
          </h3>
        )}
        {displayimage ? (
          <div class="flex flex-col sm:flex-row gap-3 mt-1">
            <p class="text-sm text-gray-600 leading-relaxed flex-1">{cleanExcerpt}</p>
            <img
              src={displayimage.src}
              alt={displayimage.alt}
              class="sm:w-32 w-full sm:h-24 h-40 object-cover rounded-lg flex-shrink-0"
            />
          </div>
        ) : (
          <p class="text-sm text-gray-600 leading-relaxed">{cleanExcerpt}</p>
        )}
        {!shortnews && (
          <a href={`/posts/${slug}`} class="text-xs text-[#552d62] hover:underline mt-1 inline-block">Read more →</a>
        )}
      </div>
    </div>
  </div>
</li>
