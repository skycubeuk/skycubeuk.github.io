# docker-compose.override.yml
# Copy this file to docker-compose.override.yml on your VPS and fill in your values.
# Docker Compose merges it with docker-compose.yml automatically — git never touches it.
#
# Customise the entrypoint ("websecure") and certresolver ("letsencrypt") to match
# whatever your Traefik instance uses.

services:
  oauth-proxy:
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.oauth-proxy.rule=Host(`cms.skycube.me.uk`)"
      - "traefik.http.routers.oauth-proxy.entrypoints=websecure"
      - "traefik.http.routers.oauth-proxy.tls=true"
      - "traefik.http.routers.oauth-proxy.tls.certresolver=letsencrypt"
      - "traefik.http.services.oauth-proxy.loadbalancer.server.port=3000"
