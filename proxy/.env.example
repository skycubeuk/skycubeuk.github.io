# OAuth proxy environment variables
# Copy this file to .env and fill in your values.
#
# GitHub OAuth App setup:
#   1. Go to GitHub → Settings → Developer settings → OAuth Apps → New OAuth App
#   2. Homepage URL:               https://skycubeuk.github.io
#   3. Authorization callback URL: https://cms.skycube.me.uk/callback
#   4. Copy the Client ID and generate a Client Secret below.

GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret

# The origin of the site that hosts the Decap CMS /admin page.
# The proxy will only send OAuth tokens to postMessage requests from this origin.
# Must match the scheme + host (no trailing slash) of your live site.
ALLOWED_ORIGIN=https://skycubeuk.github.io

# Port the HTTP server listens on (Traefik handles TLS termination externally)
PORT=3000
